/data
/app/node_modules
/app/dist
/cli/node_modules
/cli/dist
# bun is not this repo's package manager (cli uses npm + package-lock.json);
# a stray bun.lock appears when tooling runs `bun install` in the worktree.
bun.lock
.DS_Store
.env
.deploy-secret
.deploy.log
# Ignore local Claude config (settings.local.json, worktrees/) but track the
# project's checked-in skills. A parent dir excluded as `.claude/` can't have
# children re-included, so exclude its contents with `/*` and negate skills/.
.claude/*
!.claude/skills/
/compose.override.yaml
