/data
/app/node_modules
/app/dist
/cli/node_modules
/cli/dist
/e2e/node_modules
/e2e/test-results
/e2e/playwright-report
# bun is not this repo's package manager (cli uses npm + package-lock.json);
# a stray bun.lock appears when tooling runs `bun install` in the worktree.
bun.lock
.DS_Store
.env
.deploy-secret
.deploy.log
# Ignore local Claude config (settings.local.json, worktrees/) but track the
# project's checked-in skills. A parent dir excluded as `.claude/` can't have
# children re-included, so exclude its contents with `/*` and negate skills/.
.claude/*
!.claude/skills/
/compose.override.yaml

# /design-sync — staged converter, regenerated build output, machine state.
# The durable inputs under .design-sync/ (config.json, NOTES.md, conventions.md,
# previews/, overrides/) ARE committed; only the regenerated/cache paths below
# are ignored.
/.ds-sync/
/ds-bundle/
/.design-sync/.cache/
/.design-sync/learnings/
/.design-sync/node_modules
/app/ds-types/
/app/ds-dist/
