SERVER_NAME=hisohiso.org
MERCURE_PUBLISHER_JWT_KEY=change-me-publisher
MERCURE_SUBSCRIBER_JWT_KEY=change-me-subscriber
MERCURE_HUB_URL=https://hisohiso.org/.well-known/mercure

# Web push (VAPID). scripts/deploy.sh auto-generates these on the server the
# first time it runs if VAPID_PUBLIC_KEY is empty, so you can leave them blank.
# To mint by hand instead: bun scripts/gen-vapid.mjs you@example.com
# Leaving them unset disables push entirely (the /push* endpoints answer 503).
# VAPID_SUBJECT must be a real mailto:/https: contact with a routable domain —
# Apple's push service rejects localhost or bare hostnames with 403 BadJwtToken.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
