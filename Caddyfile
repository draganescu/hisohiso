{
	frankenphp
	order mercure before php_server
	order mercure before handle
}

{$SERVER_NAME} {
	# Mercure Hub
	mercure {
		publisher_jwt {$MERCURE_PUBLISHER_JWT_KEY}
		subscriber_jwt {$MERCURE_SUBSCRIBER_JWT_KEY}
		anonymous
	}

	# PHP Backend API
	@api path /api/*
	handle @api {
		route {
			root * /app/server
			php_server
		}
	}

	# Landing page (static)
	@landing path / /styles.css /security /security.html /og.png
	handle @landing {
		rewrite /security /security.html
		header Cache-Control "no-cache, must-revalidate"
		root * /app/landing
		file_server
	}

	# Legacy path-based room URLs → redirect to hash-based
	@roomsecret path_regexp secret ^/([A-Za-z0-9_-]{20,})$
	handle @roomsecret {
		redir /room#{re.secret.1} 302
	}

	# React app (rooms)
	handle {
		root * /app/public

		# Hashed assets get long cache
		@hashed path /assets/*
		header @hashed Cache-Control "public, max-age=31536000, immutable"

		# HTML and everything else: no cache
		@html not path /assets/*
		header @html Cache-Control "no-cache, must-revalidate"

		try_files {path} /index.html
		file_server
	}
}

www.hisohiso.org {
	redir https://hisohiso.org{uri} 308
}
