{
	frankenphp
	order mercure before php_server
	order mercure before php
	order mercure before handle

	# Disable the Caddy admin API. We never `caddy reload` — every deploy
	# rebuilds the container — so the admin endpoint is pure attack surface.
	# Without this, a PHP RCE or SSRF could reach 127.0.0.1:2019 from inside
	# the container and read the running config (which holds the Mercure JWT
	# keys in cleartext) or hot-swap routes.
	admin off

	# Disable HTTP/3 (QUIC). Mercure delivers room events over a long-lived
	# SSE stream; on mobile/weak-signal networks carriers deprioritize UDP and
	# NAT rebinding breaks QUIC connection migration, so the stream gets killed
	# at the QUIC layer (H3_REQUEST_CANCELLED) and rooms silently stop
	# receiving. The one-shot `GET /` degrades to TCP fine — that's why the
	# site "loads" but rooms stall. Restricting to h1/h2 keeps SSE on TCP,
	# which recovers from the same conditions. See issue #118. (The matching
	# UDP/443 port publish is also removed from compose.prod.yaml.)
	servers {
		protocols h1 h2
	}
}

{$SERVER_NAME} {
	# Security headers applied to every response on this site.
	# - HSTS pins HTTPS for return visits.
	# - CSP: an XSS in a future dependency could exfiltrate the room secret
	#   from `location.hash`. `connect-src 'self'` blocks fetch/SSE to any
	#   other origin; `frame-ancestors 'none'` blocks clickjacking the
	#   knock-approval UI from an attacker page.
	# - `-Server` / `-X-Powered-By` strip the version-fingerprinting headers
	#   Caddy and FrankenPHP set by default.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com data:; connect-src 'self'; img-src 'self' data: blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "interest-cohort=(), geolocation=(), camera=(), microphone=()"
		# Flush the HTTP/3 advertisement we previously served with a 30-day TTL
		# (`alt-svc: h3=":443"; ma=2592000`). Clients cache that and keep
		# attempting QUIC long after we stop advertising it; `Alt-Svc: clear`
		# tells them to drop the cached entry and fall back to h1/h2. Keep this
		# for ~2 weeks (until ~2026-06-12), then remove it. See issue #118.
		Alt-Svc "clear"
		-Server
		-X-Powered-By
	}

	# Mercure Hub — anonymous subscribers are NOT allowed. Every subscriber
	# must present a JWT (Authorization: Bearer or mercureAuthorization
	# cookie) whose mercure.subscribe claim lists the topics they want.
	# Events are published with private=on, so the hub gates delivery per
	# topic against each subscriber's claim.
	mercure {
		publisher_jwt {$MERCURE_PUBLISHER_JWT_KEY}
		subscriber_jwt {$MERCURE_SUBSCRIBER_JWT_KEY}
		# Send `: heartbeat\n\n` every 30s so an idle SSE connection produces
		# regular bytes. Combined with the client-side stall watchdog in
		# sse-client.ts, this lets a daemon detect a silently dead socket
		# (NAT/proxy timeout that ate the FIN) within ~90s and reconnect.
		heartbeat 30s
	}

	# PHP Backend API.
	# FrankenPHP 1.12 uses a single global PHP worker root (/app/public from
	# the base image), so per-handle `root *` doesn't change which file
	# `php` executes. We worked with that by COPY'ing ./server to
	# /app/public/api in the Dockerfile, so /app/public/api/index.php is the
	# entry point under the worker's natural root.
	#
	# try_files {path} /api/index.php: for /api/stats, {path} doesn't exist on
	# disk, so internal SCRIPT_NAME becomes /api/index.php. PHP sees
	# REQUEST_URI=/api/stats (preserved) and dispatches by parse_url(REQUEST_URI).
	@api path /api/*
	handle @api {
		root * /app/public
		try_files {path} /api/index.php
		php
	}

	# NOTE: the landing page + static content pages (formerly served here from
	# /app/landing) now live on a separate marketing host at the apex domain.
	# This container serves only the React app + /api/* + Mercure under the
	# app subdomain. `/` falls through to the React app's own landing.

	# React app (rooms)
	handle {
		root * /app/public

		# Hashed assets get long cache
		@hashed path /assets/*
		header @hashed Cache-Control "public, max-age=31536000, immutable"

		# HTML and everything else: no cache
		@html not path /assets/*
		header @html Cache-Control "no-cache, must-revalidate"

		try_files {path} /index.html
		file_server
	}
}
